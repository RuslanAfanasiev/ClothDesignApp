generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  ownerId     String
  status      ProjectStatus @default(DRAFT)
  sketches    Sketch[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Sketch {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?
  notes     String?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  category    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}
