generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  ownerId     String
  status      ProjectStatus @default(DRAFT)
  sketches    Sketch[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Sketch {
  id         String    @id @default(uuid())
  name       String
  imageUrl   String?
  notes      String?
  projectId  String
  templateId String?
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  category    String?
  isPublic    Boolean  @default(true)
  sketches    Sketch[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}
